# ── KaamSetu Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values

# REQUIRED: Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTIONAL: WhatsApp Business API (Meta for Developers)
# Get from https://developers.facebook.com → WhatsApp → Getting Started
WHATSAPP_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=kaamsetu_secret

# Server port (default: 3001)
PORT=3001
